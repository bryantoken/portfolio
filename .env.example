# ─────────────────────────────────────────────────────────────
# bryantoken — variáveis de ambiente (copie para .env e preencha)
# NUNCA comite o .env — ele está no .gitignore. O repo é público.
# ─────────────────────────────────────────────────────────────

# Postgres. Local (docker): postgresql://user:senha@localhost:5433/bryantoken?schema=public
# No Railway: adicione o plugin PostgreSQL e referencie ${{ Postgres.DATABASE_URL }}
DATABASE_URL="postgresql://user:senha@localhost:5432/bryantoken?schema=public"

# Segredo de sessão do Auth.js. Gere um forte com:  npx auth secret
AUTH_SECRET="troque-por-um-segredo-forte"

# Confia no host do proxy (Railway/Vercel). Deixe "true" em produção.
AUTH_TRUST_HOST="true"

# Admin (único que pode publicar). O seed cria/atualiza este usuário.
# ⚠️ Defina uma senha FORTE aqui — é com ela que o admin faz login.
#    NÃO reutilize senha compartilhada em chat.
ADMIN_EMAIL="voce@exemplo.com"
ADMIN_PASSWORD="defina-uma-senha-forte"
ADMIN_USERNAME="bryan"
ADMIN_NAME="Bryan Borges"

# URL pública do site (usada no RSS/metadados). Ex.: https://bryantoken.up.railway.app
SITE_URL="http://localhost:3000"
